aulas.tonicoimbra.com {
    # Arquivos estáticos: servidos diretamente pelo Caddy
    handle /static/* {
        root * /srv/professordash
        file_server
    }

    # Demais requests → Gunicorn
    reverse_proxy app:8000

    # Logs
    log {
        output file /var/log/caddy/access.log
        format json
    }
}
